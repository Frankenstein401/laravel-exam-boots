        <!-- Filter & Search Box -->
        <div class="bg-white border border-gray-200 rounded-xl p-4 mb-6 shadow-sm">
            <form action="{{ route('{{tableName}}.index') }}" method="GET" class="flex flex-col md:flex-row gap-4">
