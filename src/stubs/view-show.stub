<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail {{ModelName}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900 font-sans">
    <div class="max-w-2xl mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold tracking-tight">Detail {{ModelName}}</h1>
            <a href="{{ route('{{tableName}}.index') }}" class="text-gray-600 hover:text-gray-900 text-sm">Kembali</a>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <h2 class="text-lg font-bold text-gray-900 mb-4">{{ ${{modelNameLower}}->name ?? 'Detail Info' }}</h2>
            
            <div class="space-y-3">
                <div class="grid grid-cols-3 py-2 border-b border-gray-100 text-sm">
                    <span class="text-gray-500 font-medium">ID</span>
                    <span class="col-span-2 text-gray-900 font-mono">#{{ ${{modelNameLower}}->id }}</span>
                </div>
                <div class="grid grid-cols-3 py-2 border-b border-gray-100 text-sm">
                    <span class="text-gray-500 font-medium">Dibuat Pada</span>
                    <span class="col-span-2 text-gray-900">{{ ${{modelNameLower}}->created_at->format('d M Y H:i') }}</span>
                </div>
                <div class="grid grid-cols-3 py-2 border-b border-gray-100 text-sm">
                    <span class="text-gray-500 font-medium">Terakhir Diperbarui</span>
                    <span class="col-span-2 text-gray-900">{{ ${{modelNameLower}}->updated_at->format('d M Y H:i') }}</span>
                </div>
            </div>

            <div class="mt-6 flex justify-end space-x-2">
                <a href="{{ route('{{tableName}}.edit', ${{modelNameLower}}->id) }}" class="bg-amber-600 hover:bg-amber-500 text-white px-4 py-2 rounded-lg text-sm font-semibold transition">Edit Data</a>
            </div>
        </div>
    </div>
</body>
</html>
